<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        jcr:title="Agent Test - Content Tile"
        cq:template="/conf/d2site/settings/wcm/templates/page-content"
        sling:resourceType="d2site/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="d2site/components/container"
            layout="responsiveGrid">
            <container
                jcr:primaryType="nt:unstructured"
                sling:resourceType="d2site/components/container">
                <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="d2site/components/container"
                    layout="responsiveGrid">

                    <!-- Instance 1: All fields populated (happy path) -->
                    <contenttile_full
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="d2site/components/contenttile"
                        iconPath="/content/dam/d2site/icons/star.svg"
                        headline="Featured Service"
                        subtitle="We offer the best quality services for your needs"
                        backgroundColor="blue"/>

                    <!-- Instance 2: Empty / minimal (edge case) -->
                    <contenttile_empty
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="d2site/components/contenttile"/>

                </container>
            </container>
        </root>
    </jcr:content>
</jcr:root>
