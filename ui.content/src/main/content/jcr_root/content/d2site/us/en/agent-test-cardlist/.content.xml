<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="cq:PageContent"
        jcr:title="Agent Test - Card List"
        cq:template="/conf/d2site/settings/wcm/templates/page-content"
        sling:resourceType="d2site/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="d2site/components/container"
            layout="responsiveGrid">
            <container
                jcr:primaryType="nt:unstructured"
                sling:resourceType="d2site/components/container">
                <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="d2site/components/container"
                    layout="responsiveGrid">

                    <!-- Instance 1: 3-column layout with all fields -->
                    <cardlist_full
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="d2site/components/cardlist"
                        layout="3">
                        <items jcr:primaryType="nt:unstructured">
                            <item0
                                jcr:primaryType="nt:unstructured"
                                imagePath="/content/dam/d2site/asset.jpg"
                                title="Card One"
                                description="This is the first card with all fields populated."
                                ctaLabel="Learn More"
                                ctaLink="/content/d2site/us/en"/>
                            <item1
                                jcr:primaryType="nt:unstructured"
                                imagePath="/content/dam/d2site/asset.jpg"
                                title="Card Two"
                                description="This is the second card with complete data."
                                ctaLabel="Read More"
                                ctaLink="/content/d2site/us/en"/>
                            <item2
                                jcr:primaryType="nt:unstructured"
                                imagePath="/content/dam/d2site/asset.jpg"
                                title="Card Three"
                                description="This is the third card for a 3-column grid."
                                ctaLabel="Explore"
                                ctaLink="/content/d2site/us/en"/>
                        </items>
                    </cardlist_full>

                    <!-- Instance 2: 2-column layout with partial fields -->
                    <cardlist_partial
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="d2site/components/cardlist"
                        layout="2">
                        <items jcr:primaryType="nt:unstructured">
                            <item0
                                jcr:primaryType="nt:unstructured"
                                title="Title Only Card"/>
                            <item1
                                jcr:primaryType="nt:unstructured"
                                title="Card With CTA"
                                ctaLabel="Click Here"
                                ctaLink="/content/d2site/us/en"/>
                        </items>
                    </cardlist_partial>

                    <!-- Instance 3: Empty component (should render nothing) -->
                    <cardlist_empty
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="d2site/components/cardlist"/>

                </container>
            </container>
        </root>
    </jcr:content>
</jcr:root>
