<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Column Control Properties"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <layout
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Column Layout"
                        fieldDescription="Select the number of columns to display"
                        name="./layout"
                        required="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <one
                                jcr:primaryType="nt:unstructured"
                                text="1 Column (Full Width)"
                                value="1"/>
                            <two
                                jcr:primaryType="nt:unstructured"
                                text="2 Columns (50% / 50%)"
                                value="2"
                                selected="{Boolean}true"/>
                            <three
                                jcr:primaryType="nt:unstructured"
                                text="3 Columns (33% / 33% / 33%)"
                                value="3"/>
                            <four
                                jcr:primaryType="nt:unstructured"
                                text="4 Columns (25% / 25% / 25% / 25%)"
                                value="4"/>
                        </items>
                    </layout>
                    <columnPadding
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Column Padding"
                        fieldDescription="Padding inside each column"
                        name="./columnPadding">
                        <items jcr:primaryType="nt:unstructured">
                            <none
                                jcr:primaryType="nt:unstructured"
                                text="None"
                                value="none"
                                selected="{Boolean}true"/>
                            <small
                                jcr:primaryType="nt:unstructured"
                                text="Small - 8px"
                                value="small"/>
                            <medium
                                jcr:primaryType="nt:unstructured"
                                text="Medium - 16px"
                                value="medium"/>
                            <large
                                jcr:primaryType="nt:unstructured"
                                text="Large - 32px"
                                value="large"/>
                        </items>
                    </columnPadding>
                    <columnGap
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Column Gap"
                        fieldDescription="Spacing between columns"
                        name="./columnGap">
                        <items jcr:primaryType="nt:unstructured">
                            <none
                                jcr:primaryType="nt:unstructured"
                                text="None"
                                value="none"
                                selected="{Boolean}true"/>
                            <small
                                jcr:primaryType="nt:unstructured"
                                text="Small - 8px"
                                value="small"/>
                            <medium
                                jcr:primaryType="nt:unstructured"
                                text="Medium - 16px"
                                value="medium"/>
                            <large
                                jcr:primaryType="nt:unstructured"
                                text="Large - 32px"
                                value="large"/>
                        </items>
                    </columnGap>
                </items>
            </column>
        </items>
    </content>
</jcr:root>
